<UserControl
    x:Class="DevDeck.Controls.ActionButtonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Button x:Name="ActionButton"
            MinHeight="44"
            Padding="12,4,12,4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{ThemeResource ControlCornerRadius}"
            Click="ActionButton_Click">
        
        <Button.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Chạy Action" Click="RunAction_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Play"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Dừng Action" Click="StopAction_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Stop"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Tùy chỉnh cho Project..." Click="Customize_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Reset về mặc định" Click="Reset_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Refresh"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Gỡ khỏi Project" Click="RemoveFromProject_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Delete"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Button.ContextFlyout>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Status Icons / Progress -->
            <Grid Grid.Column="0" Margin="0,0,10,0" Width="20" Height="20">
                <SymbolIcon x:Name="DefaultSymbolIcon" Symbol="Play" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Image x:Name="CustomIconImage" Visibility="Collapsed" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <FontIcon x:Name="DefaultIcon" Glyph="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <FontIcon x:Name="SuccessIcon" Glyph="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="16" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <FontIcon x:Name="FailedIcon" Glyph="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <ProgressRing x:Name="RunningRing" Width="16" Height="16" IsActive="False" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>
 
            <!-- Action Name -->
            <TextBlock x:Name="ActionNameText" Text="Action Name" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" Grid.Column="1"/>
        </Grid>
    </Button>
</UserControl>
