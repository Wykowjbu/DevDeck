<ContentDialog
    x:Class="DevDeck.Dialogs.ProjectActionOverrideDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevDeck.Models"
    Title="Cấu hình Action riêng cho Project"
    PrimaryButtonText="Lưu tùy chỉnh"
    CloseButtonText="Hủy"
    DefaultButton="Primary">

    <Grid Width="460" Margin="0,8,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="12" Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="DialogSubheaderText" Text="Tùy chỉnh riêng cho Project hiện tại" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
            
            <TextBox x:Name="NameOverrideInput" Header="Tên hiển thị ghi đè" PlaceholderText="Nhập tên riêng (để trống để dùng tên gốc)..." IsSpellCheckEnabled="False"/>
            <TextBox x:Name="GroupNameOverrideInput" Header="Nhóm hiển thị ghi đè" PlaceholderText="Nhập nhóm riêng (để trống để dùng nhóm gốc)..." IsSpellCheckEnabled="False"/>
        </StackPanel>

        <!-- Overrides for confirmation and failure behavior -->
        <StackPanel Spacing="8" Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Hành vi chạy" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <ComboBox x:Name="RequireConfirmationInput" Header="Yêu cầu xác nhận trước khi chạy" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Dùng mặc định (Không ghi đè)"/>
                <ComboBoxItem Content="Bắt buộc xác nhận"/>
                <ComboBoxItem Content="Bỏ qua xác nhận (Chạy ngay)"/>
            </ComboBox>
            <ComboBox x:Name="StopOnFailureInput" Header="Dừng nếu bước trước đó thất bại" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Dùng mặc định (Không ghi đè)"/>
                <ComboBoxItem Content="Dừng ngay lập tức"/>
                <ComboBoxItem Content="Vẫn tiếp tục chạy"/>
            </ComboBox>
        </StackPanel>

        <!-- Steps override -->
        <Grid Grid.Row="2" Height="220">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Các bước chạy (Steps)" Style="{StaticResource BodyStrongTextBlockStyle}" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8"/>

            <ListView x:Name="StepsListView" SelectionChanged="StepsListView_SelectionChanged" Grid.Row="1" Grid.Column="0" BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundListLowBrush}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" Style="{StaticResource BodyTextBlockStyle}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="12,0,0,0">
                <StackPanel x:Name="StepDetailPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Name="StepTypeText" Text="Loại bước: ShellCommand" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <TextBox x:Name="CommandTextOverrideInput" Header="Lệnh ghi đè (Command Override)" TextWrapping="Wrap" AcceptsReturn="True" Height="80" IsSpellCheckEnabled="False" PlaceholderText="Để trống để dùng lệnh gốc" TextChanged="CommandTextOverrideInput_TextChanged"/>
                    <TextBox x:Name="WorkingDirectoryOverrideInput" Header="Thư mục làm việc ghi đè" IsSpellCheckEnabled="False" PlaceholderText="Để trống để dùng mặc định" TextChanged="WorkingDirectoryOverrideInput_TextChanged"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ContentDialog>
