<UserControl
    x:Class="DevDeck.Controls.TerminalPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DevDeck.Models"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Terminal Header & Tabs Toolbar -->
        <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="12,4,12,4" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="12">
                <TextBlock Text="Terminal" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,8,0"/>
                
                <!-- Terminal Tabs list -->
                <ListView x:Name="TabsListView" 
                          SelectionMode="Single"
                          SelectionChanged="TabsListView_SelectionChanged"
                          ScrollViewer.HorizontalScrollMode="Auto"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,2,8,2"/>
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="Margin" Value="0,0,4,0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                <Button Content="×" 
                                        Background="Transparent" 
                                        BorderBrush="Transparent" 
                                        Padding="4" 
                                        MinWidth="32"
                                        MinHeight="32"
                                        FontSize="12" 
                                        VerticalAlignment="Center" 
                                        Click="CloseTabButton_Click"
                                        DataContext="{Binding}"
                                        AutomationProperties.Name="Đóng tab terminal"
                                        ToolTipService.ToolTip="Đóng tab terminal"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Background="Transparent"
                        BorderBrush="Transparent"
                        MinWidth="40"
                        MinHeight="40"
                        VerticalAlignment="Center"
                        Click="NewTabButton_Click"
                        AutomationProperties.Name="Mở tab terminal mới"
                        ToolTipService.ToolTip="Mở tab terminal mới">
                    <SymbolIcon Symbol="Add"/>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="8">
                <Button Content="Xóa màn hình" Click="ClearButton_Click" AutomationProperties.Name="Xóa màn hình terminal"/>
                <Button Content="Dừng tiến trình" Click="KillButton_Click" AutomationProperties.Name="Dừng tiến trình terminal"/>
                <Button Content="Ẩn terminal" x:Name="HideButton" Click="HideButton_Click" AutomationProperties.Name="Ẩn panel terminal"/>
            </StackPanel>
        </Grid>

        <!-- WebView2 Terminal Host -->
        <Grid Grid.Row="1" Background="Black">
            <WebView2 x:Name="TerminalWebView" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      NavigationCompleted="TerminalWebView_NavigationCompleted"
                      AutomationProperties.Name="Terminal"/>
            
            <TextBlock x:Name="NoSessionsText" 
                       Text="Không có session terminal nào đang hoạt động. Bấm '+' để tạo mới." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                       Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
