<ContentDialog
    x:Class="DevDeck.Dialogs.WorkspaceEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cấu hình Workspace"
    PrimaryButtonText="Lưu Workspace"
    CloseButtonText="Hủy"
    DefaultButton="Primary">

    <StackPanel Spacing="16" Width="300" Margin="0,8,0,8">
        <TextBox x:Name="WorkspaceNameInput" Header="Tên Workspace" PlaceholderText="Nhập tên workspace..." IsSpellCheckEnabled="False"/>
        
        <ComboBox x:Name="AccentColorInput" Header="Màu chủ đạo" HorizontalAlignment="Stretch" SelectedIndex="0">
            <ComboBoxItem Content="Mặc định"/>
            <ComboBoxItem Content="Blue"/>
            <ComboBoxItem Content="Green"/>
            <ComboBoxItem Content="Red"/>
            <ComboBoxItem Content="Purple"/>
            <ComboBoxItem Content="Orange"/>
        </ComboBox>
    </StackPanel>
</ContentDialog>
