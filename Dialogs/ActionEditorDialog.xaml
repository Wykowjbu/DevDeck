<ContentDialog
    x:Class="DevDeck.Dialogs.ActionEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cấu hình Action"
    PrimaryButtonText="Lưu Action"
    CloseButtonText="Hủy"
    DefaultButton="Primary">

    <Grid Width="500" MinHeight="400" Margin="0,8,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- General Info -->
        <StackPanel Spacing="12" Grid.Row="0" Margin="0,0,0,16">
            <TextBox x:Name="ActionNameInput" Header="Tên Action" PlaceholderText="Ví dụ: Git Pull, Run API..." IsSpellCheckEnabled="False"/>
            <TextBox x:Name="GroupNameInput" Header="Nhóm (Group)" PlaceholderText="Ví dụ: Source Control, Development..." IsSpellCheckEnabled="False"/>
            
            <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,8,0,0">
                <CheckBox x:Name="RequireConfirmInput" Content="Xác nhận trước khi chạy"/>
                <CheckBox x:Name="StopOnFailureInput" Content="Dừng nếu lỗi" IsChecked="True"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="ValidationErrorText"
                   Grid.Row="1"
                   TextWrapping="WrapWholeWords"
                   Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                   Visibility="Collapsed"
                   Margin="0,0,0,12"/>

        <!-- Steps Manager -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Steps List -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView x:Name="StepsListView" Header="Các bước chạy (Steps)" SelectionChanged="StepsListView_SelectionChanged"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Grid.Row="1" Margin="0,8,0,0">
                    <Button Content="Thêm Shell" Click="AddShellStep_Click"/>
                    <Button Content="Thêm Delay" Click="AddDelayStep_Click"/>
                    <Button Content="Xóa" Click="RemoveStep_Click"/>
                </StackPanel>
            </Grid>

            <!-- Step Editor Detail -->
            <StackPanel x:Name="StepDetailPanel" Grid.Column="1" Spacing="12" Visibility="Collapsed">
                <TextBlock x:Name="StepTypeText" Text="Kiểu Step" FontWeight="SemiBold"/>
                
                <!-- Command Text field (for ShellCommand) -->
                <TextBox x:Name="CommandTextInput" Header="Lệnh Command" PlaceholderText="Nhập lệnh (ví dụ: git pull)..." TextChanged="CommandTextInput_TextChanged" AcceptsReturn="True" Height="100" IsSpellCheckEnabled="False"/>
                <ComboBox x:Name="ShellInput" Header="Shell" HorizontalAlignment="Stretch" SelectionChanged="ShellInput_SelectionChanged">
                    <ComboBoxItem Content="PowerShell 7"/>
                    <ComboBoxItem Content="Windows PowerShell"/>
                    <ComboBoxItem Content="Command Prompt (CMD)"/>
                    <ComboBoxItem Content="Git Bash"/>
                </ComboBox>
                <ComboBox x:Name="OutputModeInput" Header="Cách chạy" HorizontalAlignment="Stretch" SelectionChanged="OutputModeInput_SelectionChanged">
                    <ComboBoxItem Content="Chạy ẩn"/>
                    <ComboBoxItem Content="Mở terminal ngoài"/>
                </ComboBox>
                
                <!-- Delay field (for Delay) -->
                <NumberBox x:Name="DelayInput" Header="Thời gian chờ (ms)" Value="1000" ValueChanged="DelayInput_ValueChanged" SpinButtonPlacementMode="Compact"/>
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>
